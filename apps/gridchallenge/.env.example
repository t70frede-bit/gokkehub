# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these at: Supabase Dashboard → Project Settings → API
# Copy this file to .env.local and fill in your values (never commit .env.local).
VITE_SUPABASE_URL=               # e.g. https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=          # Safe to use client-side; controls RLS access
# NEVER put SUPABASE_SERVICE_ROLE_KEY in any client-side or .env file
