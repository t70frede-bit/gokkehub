# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real credentials.

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=                    # From Supabase project settings
SUPABASE_ANON_KEY=               # Safe to use client-side
SUPABASE_SERVICE_ROLE_KEY=       # NEVER expose this client-side

# ── Cloudflare ────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=           # From Cloudflare dashboard
CLOUDFLARE_API_TOKEN=            # Create at dash.cloudflare.com/profile/api-tokens

# ── Cloudflare resource IDs (already created) ─────────────
CF_KV_SESSION_ID=5c6e3465296c41e986c086727c8459e7
CF_D1_DATABASE_ID=9048a034-49ea-41ba-8743-c01737b9a96d
CF_R2_BUCKET_NAME=gokkehub-avatars   # Enable R2 in CF dashboard first

# ── Spotify ───────────────────────────────────────────────
SPOTIFY_CLIENT_ID=               # From developer.spotify.com
SPOTIFY_CLIENT_SECRET=           # NEVER expose this client-side
SPOTIFY_REDIRECT_URI=            # e.g. https://account.gokkehub.com/auth/spotify/callback

# ── Discord ───────────────────────────────────────────────
DISCORD_CLIENT_ID=               # From discord.com/developers
DISCORD_CLIENT_SECRET=           # NEVER expose this client-side
DISCORD_REDIRECT_URI=            # e.g. https://account.gokkehub.com/auth/discord/callback

# ── Steam ─────────────────────────────────────────────────
STEAM_API_KEY=                   # From steamcommunity.com/dev/apikey
STEAM_REALM=                     # e.g. https://gokkehub.com
STEAM_RETURN_URL=                # e.g. https://account.gokkehub.com/auth/steam/callback

# ── App ───────────────────────────────────────────────────
SESSION_SECRET=                  # Random 32+ char string, generate with: openssl rand -hex 32
COOKIE_DOMAIN=.gokkehub.com      # Leading dot = valid on all subdomains
NODE_ENV=development
