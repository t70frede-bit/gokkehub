# Discord bot credentials — get these from
# https://discord.com/developers/applications → your app → Bot / General Info
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# Supabase — same project as the Cloudflare Pages Functions.
# The service-role key is needed to read tl_rooms / tl_rounds without RLS.
# Keep this secret; bot env vars only.
SUPABASE_URL=https://verbxfbfurachhxztkob.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional — narrow the bot to a single guild during development for
# faster slash-command sync. Remove for production (global commands).
DISCORD_DEV_GUILD_ID=

# ── HTTP audio proxy (for musix "all-clients-stream" audio mode) ───────
# The bot exposes /stream/:videoId on this port so browser clients can
# fetch yt-dlp audio without each running yt-dlp themselves. Reverse-
# proxy this behind your own HTTPS domain (e.g. musix-bot.example.com).
PORT=8081

# Shared secret. If set, /stream requests must include ?token=<value>
# or X-Stream-Token header matching this value. Recommended for any
# public deployment so strangers can't burn your bandwidth streaming
# YouTube through your server.
#
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# or:
#   openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
#
# Pick once, paste here + into the matching streamProxyToken setting
# in the musix lobby. Leave empty to disable auth (local dev only).
STREAM_TOKEN=

# Comma-separated CORS allow-list for the audio proxy. Default covers
# production musix.gokkehub.com + local dev. Add your subdomain if
# you fork. "*" allows any origin (not recommended in production).
STREAM_CORS=https://musix.gokkehub.com,http://localhost:5173,http://localhost:3000
